# Google Nest Authentication
GOOGLE_MASTER_TOKEN=aas_...
GOOGLE_USERNAME=your.email@gmail.com
NEST_DEVICE_ID=your-device-id

# Resend Email
RESEND_API_KEY=re_...
ALERT_EMAIL_TO=your.email@example.com
ALERT_EMAIL_FROM=alerts@xeroshot.org

# Camera Location (for daylight filtering)
CAMERA_LATITUDE=51.5074
CAMERA_LONGITUDE=-0.1278

# Detection
YOLO_MODEL=yolo26s.pt
YOLO_CONFIDENCE_THRESHOLD=0.4
YOLO_BATCH_SIZE=16
CROP_PADDING=0.2

# Region of Interest (fraction 0.0–1.0)
ROI_Y_START=0.0
ROI_Y_END=0.33
ROI_X_START=0.0
ROI_X_END=1.0

# Frame Sampling
FPS_SAMPLE=2

# Scooter Detection (experimental)
SCOOTER_FPS_SAMPLE=4
SCOOTER_DISPLACEMENT_THRESHOLD=40.0
SCOOTER_PERSON_CONFIDENCE=0.4
SCOOTER_MAX_MATCH_DISTANCE=200.0

# Polling
POLL_INTERVAL_SECONDS=120
