# Google Nest Authentication
GOOGLE_MASTER_TOKEN=aas_...
GOOGLE_USERNAME=your.email@gmail.com
NEST_DEVICE_ID=your-device-id

# Claude Vision Verification (optional)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_VISION_MODEL=claude-sonnet-4-6
CLAUDE_VISION_PROMPT=Is there a motorized two-wheeled vehicle in this image — such as a motorcycle, motorbike, scooter, moped, or e-bike? People may be riding or standing near it. Do NOT count baby strollers, prams, pushchairs, wagons, wheelchairs, shopping carts, or any non-motorized wheeled object. Answer "yes" or "no" only. Answer "yes" only if a motorized two-wheeled vehicle is clearly visible. Answer "no" for everything else.

# Email Settings
RESEND_API_KEY=re_...
ALERT_EMAIL_TO=your.email@example.com
ALERT_EMAIL_FROM=alerts@example.org

# Camera Location (for daytime-only analysis)
CAMERA_LATITUDE=51.5074
CAMERA_LONGITUDE=-0.1278

# Region of Interest Cropping (fraction 0.0–1.0)
# Y top to bottom, X left to right
ROI_Y_START=0.0
ROI_Y_END=1.0
ROI_X_START=0.0
ROI_X_END=1.0

# Object Detection Model
YOLO_MODEL=yolo_models/yolo26s.pt
YOLO_BATCH_SIZE=16
CROP_PADDING=0.2

# Vehicle Detection (VEH)
VEH_FPS_SAMPLE=4
VEH_CONFIDENCE_THRESHOLD=0.4

# High-Speed Person Detection (HSP)
HSP_FPS_SAMPLE=4
HSP_PERSON_CONFIDENCE_THRESHOLD=0.4
HSP_MAX_MATCH_DISTANCE=120
HSP_DISPLACEMENT_THRESHOLD=360
